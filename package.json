{
  "name": "stocksphere",
  "version": "2.0.0",
  "description": "StockSphere Inventory Management – React frontend + FastAPI backend",
  "scripts": {
    "start": "concurrently \"npm run start-frontend\" \"npm run start-backend\"",
    "start-frontend": "npm start --prefix frontend",
    "start-backend": "cd backend && venv312\\Scripts\\python -m uvicorn app.main:app --host 0.0.0.0 --port 5000 --reload",
    "test-backend": "cd backend && venv312\\Scripts\\python -m pytest tests/ -v"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
